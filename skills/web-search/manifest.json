{
  "name": "web-search",
  "version": "1.0.0",
  "description": "Real-time web search via z-ai-web-dev-sdk. Returns structured search results with URLs, snippets, metadata. Bypasses knowledge cutoff.",
  "category": "ai-media",
  "priority": 70,
  "language": "javascript",
  "cost": {
    "cpu": "low",
    "ram": "<128MB",
    "time": "1-10s per query",
    "gpu": "none",
    "network": "required",
    "llm_calls": 0
  },
  "triggers": {
    "content_contains": [
      "search",
      "find online",
      "google",
      "latest news",
      "current info",
      "web search",
      "найти",
      "поиск",
      "новости"
    ]
  },
  "inputs": {
    "schema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string"
        },
        "max_results": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 10
        },
        "lang": {
          "type": "string",
          "default": "auto"
        }
      },
      "required": [
        "query"
      ]
    }
  },
  "outputs": {
    "schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "data": {
          "type": "object",
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "snippet": {
                    "type": "string"
                  }
                }
              }
            },
            "count": {
              "type": "integer"
            }
          }
        }
      },
      "required": [
        "status",
        "confidence"
      ]
    }
  },
  "requires": {
    "node": ">=18",
    "npm_packages": [
      "z-ai-web-dev-sdk"
    ]
  },
  "dependencies": [],
  "memory": {
    "save": [
      "results"
    ],
    "load": []
  },
  "self_test": {
    "doctor_script": "doctor.py"
  },
  "validator": {
    "script": "validator.py",
    "min_confidence": 0.5
  },
  "entry_points": {
    "search": "scripts/web_search.ts"
  },
  "tags": [
    "search",
    "web",
    "google",
    "news",
    "realtime",
    "web-search"
  ],
  "entry_point": "scripts/run.py",
  "docs_only": false
}